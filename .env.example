# Environment Variables for Vaibhav Mobiles
# Copy this to .env.local and fill in your real values

# MongoDB Atlas Connection String (REQUIRED)
# Get this from MongoDB Atlas Dashboard -> Connect -> Connect your application
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/vaibhav_mobiles?retryWrites=true&w=majority
MONGODB_URI=

# Admin credentials are seeded automatically:
# Username: admin
# Password: admin123
# You can change these after first login via the database
